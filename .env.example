# Default profile: local Ollama-only runtime.
# All providers use OpenAI-compatible endpoints exposed by Ollama.

# Core
MMAA_APP_NAME=multimodal-multiagent-ai-assistant
MMAA_APP_VERSION=0.1.0
MMAA_DEBUG=false
MMAA_LOG_LEVEL=INFO

# LLM generation
MMAA_LLM_PROVIDER=openai
# MMAA_LLM_MODEL examples:
# - Ollama/local (laptop-friendly): qwen3:1.7b, qwen3:4b
# - Ollama/local (higher quality, more VRAM): qwen3:8b
# - Hosted OpenAI examples: gpt-4.1-mini, gpt-4.1
MMAA_LLM_MODEL=qwen3:4b
MMAA_LLM_API_KEY=local-placeholder
MMAA_LLM_BASE_URL=http://localhost:11434/v1
MMAA_LLM_TEMPERATURE=0.1
MMAA_LLM_MAX_TOKENS=500

# Multimodal vision/video
MMAA_MULTIMODAL_PROVIDER=openai
MMAA_MULTIMODAL_API_KEY=local-placeholder
MMAA_MULTIMODAL_BASE_URL=http://localhost:11434/v1
# MMAA_MULTIMODAL_VISION_MODEL examples:
# - Ollama/local (recommended for 8GB VRAM): qwen3-vl:2b
# - Ollama/local alternatives: qwen2.5vl:3b, llava:7b
# - Hosted OpenAI example: gpt-4o-mini
MMAA_MULTIMODAL_VISION_MODEL=qwen3-vl:2b
MMAA_MULTIMODAL_VIDEO_SAMPLE_FPS=1.0
MMAA_MULTIMODAL_VIDEO_MAX_FRAMES=24
MMAA_MULTIMODAL_VIDEO_LATENCY_BUDGET_MS=1500
MMAA_MULTIMODAL_VIDEO_ESTIMATED_MS_PER_FRAME=12.0
MMAA_MULTIMODAL_VIDEO_MAX_WINDOW_SEC=120.0
MMAA_MULTIMODAL_VIDEO_MAX_KEY_EVENTS=5
MMAA_MULTIMODAL_VIDEO_REMOTE_FETCH_TIMEOUT_SEC=20.0
MMAA_MULTIMODAL_VIDEO_MAX_REMOTE_SOURCE_BYTES=120000000
MMAA_MULTIMODAL_VIDEO_REQUIRE_FRAME_FINDINGS=true
MMAA_VISION_MAX_SOURCE_BYTES=5000000

# RAG embeddings
MMAA_RAG_EMBEDDING_PROVIDER=openai
# MMAA_RAG_EMBEDDING_MODEL examples when provider=openai:
# - Ollama/local: nomic-embed-text
# - Hosted OpenAI: text-embedding-3-small, text-embedding-3-large
# Note: multimodal embedding stack (Qwen3-VL embedding/reranker) is planned in M5.3.
MMAA_RAG_EMBEDDING_MODEL=nomic-embed-text
# MMAA_RAG_SENTENCE_TRANSFORMER_MODEL examples when provider=sentence_transformers:
# - BAAI/bge-small-en-v1.5
# - BAAI/bge-base-en-v1.5
# - intfloat/e5-small-v2
MMAA_RAG_SENTENCE_TRANSFORMER_MODEL=BAAI/bge-small-en-v1.5
MMAA_RAG_OPENAI_API_KEY=local-placeholder
MMAA_RAG_OPENAI_BASE_URL=http://localhost:11434/v1

# Cloud OpenAI profile example
# MMAA_LLM_MODEL=gpt-4.1-mini
# MMAA_LLM_API_KEY=YOUR_OPENAI_KEY
# MMAA_LLM_BASE_URL=
# MMAA_MULTIMODAL_VISION_MODEL=gpt-4o-mini
# MMAA_MULTIMODAL_API_KEY=YOUR_OPENAI_KEY
# MMAA_MULTIMODAL_BASE_URL=
# MMAA_RAG_EMBEDDING_MODEL=text-embedding-3-small
# MMAA_RAG_OPENAI_API_KEY=YOUR_OPENAI_KEY
# MMAA_RAG_OPENAI_BASE_URL=

# Vector store
MMAA_RAG_VECTOR_STORE_PROVIDER=pgvector
MMAA_DATABASE_URL=
MMAA_QDRANT_URL=
MMAA_QDRANT_API_KEY=
MMAA_QDRANT_COLLECTION_NAME=rag_chunks

# Agent orchestration
MMAA_AGENT_MAX_STEPS=6
MMAA_AGENT_TOOL_BUDGET=2
MMAA_AGENT_TOOL_TIMEOUT_SEC=2.0
MMAA_AGENT_TOOL_RETRIES=1
MMAA_AGENT_RETRIEVAL_TOP_K=5
MMAA_AGENT_CHECKPOINT_ENABLED=true
MMAA_AGENT_RESUME_FROM_CHECKPOINT=true
